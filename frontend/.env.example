# Identity provider authorize endpoint used by the Login page's OIDC implicit flow.
VITE_AUTH_AUTHORIZE_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize

# App registration (client) ID for the frontend SPA.
VITE_AUTH_CLIENT_ID=<your-client-id>

# Optional: defaults to http://localhost:5173/login in local development.
VITE_AUTH_REDIRECT_URI=http://localhost:5173/login

# Optional: defaults to "openid profile email".
VITE_AUTH_SCOPE=openid profile email

# Optional local-only helper that enables email+role simulation on /login.
VITE_ENABLE_DEV_ROLE_SIMULATION=true

# Optional auth mode:
# - idp   = external provider redirect flow (default)
# - local = backend-issued local JWT via /api/auth/local-login (recommended for local end-to-end testing)
VITE_AUTH_MODE=local

# Optional API base; point to local backend when frontend runs on :5173.
# Keep this aligned with backend/SafeHarbor/SafeHarbor/Properties/launchSettings.json.
VITE_API_BASE_URL=http://localhost:5264
