{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=SafeHarborDB;Username=postgres;Password=__SET_IN_USER_SECRETS_OR_ENV__"
  },
  "LocalAuth": {
    "Enabled": true,
    "Issuer": "safeharbor-local",
    "Audience": "safeharbor-local-client",
    "SigningKey": "__SET_IN_USER_SECRETS_OR_ENV__"
  },
  "AllowedOrigins": [
    "http://localhost:5173"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Telemetry": {
    "ServiceName": "safeharbor-api",
    "OtlpEndpoint": ""
  },
  "DevelopmentFeatures": {
    "UseInMemoryDataStore": false
  },
  "Identity": {
    "PasswordPolicy": {
      "RequiredLength": 12,
      "RequiredUniqueChars": 3,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": true,
      "MaxFailedAccessAttempts": 3,
      "DefaultLockoutMinutes": 15
    }
  }
}
